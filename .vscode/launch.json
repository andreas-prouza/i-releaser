    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File with Arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/webapp:${workspaceFolder}/etc",
                "I_RELEASER_WEBAPP_PATH": "${workspaceFolder}/webapp"
            },
            "args": [
            ]
        }
    ]
}